    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "graphql": "^16.7.1",
    "graphql-scalars": "^1.25.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-ws": "^6.0.7",
    "helmet": "^8.1.0",
    "jose": "^5.2.4",
    "multer": "^1.4.5-lts.1",
