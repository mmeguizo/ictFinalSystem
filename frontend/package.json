{
  "name": "ictsystem",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:ictsystem": "node dist/ictsystem/server/server.mjs",
    "starter": "node --max_old_space_size=4048 ./node_modules/@angular/cli/bin/ng serve",
    "superstarter": "ng serve --host 0.0.0.0 --ssl --ssl-cert ./localhost+2.pem --ssl-key ./localhost+2-key.pem",
    "codegen": "graphql-codegen --config codegen.yml",
    "codegen:watch": "graphql-codegen --config codegen.yml --watch"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.5",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/platform-server": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@angular/ssr": "^20.3.5",
    "@apollo/client": "^4.0.1",
    "@auth0/auth0-angular": "^2.3.0",
    "@types/file-saver": "^2.0.7",
    "apollo-angular": "^12.0.0",
    "chart.js": "^4.5.1",
    "express": "^5.1.0",
    "file-saver": "^2.0.5",
    "graphql": "^16",
    "graphql-ws": "^6.0.7",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "ng-zorro-antd": "^20.3.1",
    "ng2-charts": "^8.0.0",
    "ngx-quill": "^28.0.2",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.5",
    "@angular/cli": "^20.3.5",
    "@angular/compiler-cli": "^20.3.0",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/typescript": "^4.0.1",
    "@graphql-codegen/typescript-apollo-angular": "^4.0.0",
    "@graphql-codegen/typescript-operations": "^4.0.1",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
